{
  "name": "moneymanagment",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev:safe": "eslint . --max-warnings=0 && vite || (eslint . --fix && vite)",
    "preview": "vite preview",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "vercel:link": "vercel link",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "cheerio": "^1.2.0",
    "leaflet": "^1.9.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.12",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "lint-staged": "^16.3.3",
    "sass": "^1.97.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vercel": "^50.25.6",
    "vite": "^7.3.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "tsc --noEmit"
    ],
    "*.{scss,css}": [
      "echo 'Checking styles...'"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
